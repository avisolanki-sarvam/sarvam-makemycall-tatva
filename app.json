{
  "expo": {
    "name": "MakeMyCall",
    "slug": "makemycall",
    "scheme": "makemycall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141414"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.makemycall",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "backgroundColor": "#141414",
        "barStyle": "light-content"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.makemycall",
      "infoPlist": {
        "NSContactsUsageDescription": "MakeMyCall needs access to your contacts so you can pick people to call.",
        "NSUserNotificationsUsageDescription": "MakeMyCall sends you notifications about calls and updates."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-audio",
      [
        "expo-contacts",
        {
          "contactsPermission": "MakeMyCall needs access to your contacts so you can pick people to call."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "./plugins/with-extra-android-permissions",
      "expo-asset"
    ]
  }
}
